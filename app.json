{
  "expo": {
    "name": "Spent - AI Expense Log",
    "slug": "expense-tracker",
    "shortName": "Spent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/composed.png",
    "scheme": "spent",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F7FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.asadshoaib.expensetracker",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.asadshoaib.expensetracker",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/composed.png",
        "backgroundColor": "#F5F7FF"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "spent"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      ["expo-router"],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Spent to access your photos to upload receipts.",
          "cameraPermission": "Allow Spent to use the camera to photograph receipts."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Spent to use the microphone for voice expense capture.",
          "speechRecognitionPermission": "Allow Spent to recognize your speech to log expenses."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-dynamic-app-icon",
        {
          "composed": {
            "image": "./assets/icons/composed.png",
            "prerendered": true
          },
          "concerned": {
            "image": "./assets/icons/concerned.png",
            "prerendered": true
          },
          "disappointed": {
            "image": "./assets/icons/disappointed.png",
            "prerendered": true
          },
          "feral": {
            "image": "./assets/icons/feral.png",
            "prerendered": true
          },
          "final_form": {
            "image": "./assets/icons/final.png",
            "prerendered": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
