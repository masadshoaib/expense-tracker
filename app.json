{
  "expo": {
    "name": "Expense Tracker",
    "slug": "expense-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/composed.png",
    "scheme": "expenseapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F7FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.asadshoaib.expensetracker"
    },
    "android": {
      "package": "com.asadshoaib.expensetracker",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "expenseapp"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      ["expo-router"],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Expense Tracker to access your photos to upload receipts.",
          "cameraPermission": "Allow Expense Tracker to use the camera to photograph receipts."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Expense Tracker to use the microphone for voice expense capture.",
          "speechRecognitionPermission": "Allow Expense Tracker to recognize your speech to log expenses."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-dynamic-app-icon",
        {
          "icons": {
            "composed": {
              "image": "./assets/icons/composed.png",
              "prerendered": true
            },
            "concerned": {
              "image": "./assets/icons/concerned.png",
              "prerendered": true
            },
            "disappointed": {
              "image": "./assets/icons/disappointed.png",
              "prerendered": true
            },
            "feral": {
              "image": "./assets/icons/feral.png",
              "prerendered": true
            },
            "final_form": {
              "image": "./assets/icons/final.png",
              "prerendered": true
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
